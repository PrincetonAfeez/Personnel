{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./employee.schema.json",
  "title": "Employee",
  "description": "Employee record for the Personnel registry package.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "unique_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "contact_info": { "type": "string", "minLength": 1 },
    "on_site": { "type": "boolean", "default": false },
    "checked_in_at": { "type": ["string", "null"], "format": "date-time", "default": null },
    "location": { "type": ["string", "null"], "default": null },
    "department": { "type": "string", "minLength": 1 },
    "role_title": { "type": "string", "minLength": 1 },
    "hire_date": { "type": "string", "format": "date" },
    "assigned_keycard_id": { "type": "string", "minLength": 1 }
  },
  "required": [
    "unique_id",
    "name",
    "contact_info",
    "department",
    "role_title",
    "hire_date",
    "assigned_keycard_id"
  ]
}
