{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./visitor.schema.json",
  "title": "Visitor",
  "description": "Visitor record for the Personnel registry package.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "unique_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "contact_info": { "type": "string", "minLength": 1 },
    "on_site": { "type": "boolean", "default": false },
    "checked_in_at": { "type": ["string", "null"], "format": "date-time", "default": null },
    "location": { "type": ["string", "null"], "default": null },
    "host_employee_id": { "type": "string", "minLength": 1 },
    "visit_purpose": { "type": "string", "minLength": 1 },
    "expected_duration_minutes": { "type": "integer", "minimum": 1 }
  },
  "required": [
    "unique_id",
    "name",
    "contact_info",
    "host_employee_id",
    "visit_purpose",
    "expected_duration_minutes"
  ]
}
